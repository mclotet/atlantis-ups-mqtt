# NUT UPS name (as configured in nut-upsd)
UPS_NAME=ups
# Hostname or IP of the NUT server (use "nut-upsd" if running via this docker-compose)
UPS_HOST=nut-upsd
UPS_PORT=3493

# MQTT broker address
MQTT_HOST=localhost
MQTT_PORT=1883

# Polling frequency (seconds) when UPS is online
SAMPLE_RATE_ONLINE=60
# Polling frequency (seconds) when UPS is offline or data unavailable
SAMPLE_RATE_OFFLINE=10

# NUT UPS serial number (used by nut-upsd to identify the device)
UPS_SERIAL=
# NUT authentication
NUT_USER=
NUT_PASSWORD=

# USB device path for the UPS
UPS_USB_PATH=/dev/bus/usb/003

# ---------------------------------------------------------------------------
# Atlantis identity — used for MQTT topic construction and structured logging
# ---------------------------------------------------------------------------

# Physical/logical location (mqtt.md §1.2.1). "global" = rack/whole-house infrastructure
ATL_GROUP_ID=global

# Logical subsystem (mqtt.md §1.2.2). "rack" = compute/networking/UPS rack
ATL_EDGE_NODE_ID=rack

# Unique device identifier — the hostname of the publishing host (mqtt.md §1.3)
ATL_DEVICE_ID=raspberrypi5

# Service name used in structured log Resource attributes
ATL_SERVICE_NAME=ups-mqtt

# Logging environment: "development" = human-readable stdout, "production" = OTel JSON
ATL_ENV=production

# Minimum log level: DEBUG, INFO, WARN, ERROR
ATL_LOG_LEVEL=INFO

# Max MQTT log messages per minute (0 = unlimited)
ATL_MQTT_LOG_MAX_PER_MINUTE=300

# Firmware/service version reported in the MQTT birth (availability) message
FW_VERSION=1.0.0
