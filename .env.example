# NUT UPS name (as configured in nut-upsd)
UPS_NAME=ups
# Hostname or IP of the NUT server (use "nut-upsd" if running via this docker-compose)
UPS_HOST=nut-upsd
UPS_PORT=3493

# MQTT broker address
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT topic to publish UPS telemetry to
MQTT_TOPIC=atlantis/basement/data/rack/raspberrypi5/ups

# Polling frequency (seconds) when UPS is online
SAMPLE_RATE_ONLINE=60
# Polling frequency (seconds) when UPS is offline or data unavailable
SAMPLE_RATE_OFFLINE=10

# NUT UPS serial number (used by nut-upsd to identify the device)
UPS_SERIAL=
# NUT authentication
NUT_USER=
NUT_PASSWORD=

# USB device path for the UPS (default: /dev/bus/usb/003)
# Override this if your UPS is on a different USB bus/device path
UPS_USB_PATH=/dev/bus/usb/003
